if [[ $(cat /etc/os-release) =~ elementary ]]; then 
    # Fix emacs 
    alias emacs='XLIB_SKIP_ARGB_VISUALS=1 emacs'
    # This has to be run as root, so don't bother.
    # sed -i '/Exec=\/usr\/bin\/emacs25 %F/c\Exec=\/usr\/bin\/env XLIB_SKIP_ARGB_VISUALS=1 emacs24 %F' /usr/share/applications/emacs25.desktop
fi
 